# Argos user configuration
# Copy to ~/.config/argos/config.toml and edit as needed.
# All fields are optional — missing keys fall back to the defaults shown here.

[slack]
channel_id = "C0123456789"
summary_language = "Korean"

[briefing]
time = "07:00"
weekdays = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
# Max items surfaced per category (Mainstream / Alpha) in each daily briefing.
limit_per_category = 10

[interests]
topics = ["RAG", "LLM inference", "vector database"]
exclusions = ["crypto", "NFT"]

[ollama]
host = "http://localhost:11434"
model_triage = "qwen3:8b"
model_deepdive = "qwen3:32b"

[llm]
backend = "ollama"

[genealogist]
# Minimum number of embedded tech_items required to run the 32B genealogist
# branch. When the DB has fewer items (cold start), the brain pipeline skips
# the genealogist step and the 32B prewarm to save VRAM and time.
min_db_items = 50
